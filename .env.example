# CleanPlate environment template
# Copy this file to `.env` and replace placeholder values.

# Client/server endpoint
CLEANPLATE_SERVER_URL=https://127.0.0.1:8443

# Audit-log HMAC key used by activity.py
CLEANPLATE_AUDIT_HMAC_KEY=hex:replace-with-64-hex-chars

# Username-blinding HMAC key used by auth.py
CLEANPLATE_USERNAME_HMAC_KEY=hex:replace-with-64-hex-chars

# Session-signing HMAC key used by session.py
CLEANPLATE_SESSION_HMAC_KEY=hex:replace-with-64-hex-chars
